# Path to the tsa-jettons shadow JAR (built via ./gradlew :tsa-jettons:shadowJar)
TSA_JAR_PATH=../tsa-jettons/build/libs/tsa-jettons.jar

# Java 21 home directory (JDK 24 is incompatible with the analyzer)
JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home

# Server port
PORT=8080
